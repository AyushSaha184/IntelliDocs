# EMBEDDING CONFIGURATION
NVIDIA_API_KEY=your_nvidia_api_key_here
EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=baai/bge-m3
EMBEDDING_NORMALIZE=true
EMBEDDING_TIMEOUT=120.0
EMBEDDING_MAX_RETRIES=3


# Retrieval Configuration
RETRIEVAL_MODE=hybrid


# RERANKER CONFIGURATION
USE_RERANKER=true
RERANKER_MODEL=nv-rerank-qa-mistral-4b:1
MIN_CHUNKS_TO_RERANK=8
TOP_K_AFTER_RERANK=5


# LLM Configuration
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=qwen/qwen3-235b-a22b-thinking-2507
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Judge LLM Configuration
JUDGE_PROVIDER=cerebras
JUDGE_MODEL=llama3.1-8b
CEREBRAS_API_KEY=your_cerebras_api_key_here
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME= 


# PostgreSQL Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/db_name
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_SSLMODE=prefer

# Vector backend
VECTOR_BACKEND=auto
PGVECTOR_DISTANCE=cosine
PGVECTOR_PROBES=10

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase (optional, if using Supabase Postgres/Auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=rag-documents

# Upload storage backend
STORAGE_BACKEND=local

# API auth mode: auto|true|false
AUTH_REQUIRED=auto
